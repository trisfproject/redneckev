---
import { navItems, whatsappHref } from './site';
---

<footer class="border-t border-white/10 bg-black/55 py-12">
  <div class="container-shell grid gap-10 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
    <div>
      <strong class="text-xl font-black uppercase tracking-[0.22em] text-white">Redneck EV</strong>
      <p class="mt-4 max-w-md leading-7 text-zinc-400">Modern EV garage untuk service sepeda listrik, motor listrik, upgrade lithium, tuning controller, conversion, dan home service.</p>
    </div>
    <div>
      <p class="font-black uppercase tracking-[0.18em] text-zinc-200">Navigation</p>
      <div class="mt-4 grid gap-2">
        {navItems.map((item) => <a class="text-zinc-400 transition hover:text-white" href={item.href}>{item.label}</a>)}
      </div>
    </div>
    <div>
      <p class="font-black uppercase tracking-[0.18em] text-zinc-200">Contact</p>
      <a class="mt-4 inline-flex text-zinc-400 transition hover:text-white" href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp Redneck EV</a>
      <p class="mt-2 text-zinc-500">Mon-Sat, 09:00-18:00</p>
    </div>
  </div>
  <div class="container-shell mt-10 border-t border-white/10 pt-6 text-sm text-zinc-500">
    © {new Date().getFullYear()} Redneck EV. Static site built with Astro for GitHub Pages.
  </div>
</footer>
