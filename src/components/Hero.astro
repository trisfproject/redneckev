---
import { whatsappHref, withBase } from './site';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero/hero-electric-motorcycle.webp';
---

<section class="relative min-h-screen overflow-hidden pt-28">
  <Image
    class="absolute inset-0 h-full w-full object-cover opacity-40"
    src={heroImage}
    alt="Motor listrik modern di dalam bengkel EV rumahan Redneck EV Cilegon"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    widths={[640, 960, 1280, 1600]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,6,8,0.96)_0%,rgba(5,6,8,0.72)_46%,rgba(5,6,8,0.28)_100%)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-44 bg-gradient-to-t from-[#08090b] to-transparent"></div>

  <div class="container-shell relative z-10 grid min-h-[calc(100vh-7rem)] items-center gap-12 pb-20 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <p class="mb-5 inline-flex rounded-sm border border-red-500/40 bg-red-500/10 px-2.5 py-1.5 sm:px-3 sm:py-2 text-[10px] sm:text-xs font-black uppercase tracking-[0.22em] sm:tracking-[0.28em] text-red-300">Service Sepeda Listrik & Motor Listrik</p>
      <h1 class="text-balance text-4xl font-black uppercase leading-[0.95] sm:leading-[0.92] tracking-normal text-white sm:text-6xl lg:text-7xl">
        Redneck EV
        <span class="block bg-gradient-to-r from-red-500 via-orange-400 to-zinc-200 bg-clip-text text-transparent">Solutions Start Here</span>
      </h1>
      <p class="mt-6 max-w-2xl text-base sm:text-lg leading-relaxed sm:leading-8 text-zinc-300">
        Service sepeda listrik, motor listrik, upgrade battery lithium, controller tuning, EV conversion, dan home service untuk rider yang ingin kendaraannya kembali galak, rapi, dan aman.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="w-full sm:w-auto inline-flex justify-center items-center rounded-sm bg-red-600 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-white shadow-xl shadow-red-950/50 transition hover:bg-orange-500" href={withBase('contact/')}>
          Contact Us
        </a>
        <a class="w-full sm:w-auto inline-flex justify-center items-center rounded-sm border border-white/15 bg-white/5 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-white transition hover:border-orange-400/60 hover:bg-orange-500/10" href={withBase('services/')}>
          Our Services
        </a>
      </div>
    </div>

    <div class="garage-card industrial-border rounded-lg p-4 sm:p-5">
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        {[
          ['Service', 'Sepeda Listrik'],
          ['Service', 'Motor Listrik'],
          ['Lithium', 'Battery Upgrade'],
          ['On-call', 'Home Service'],
        ].map(([value, label]) => (
          <div class="rounded-sm border border-white/10 bg-black/35 p-3 sm:p-5">
            <strong class="block text-xl sm:text-3xl font-black text-orange-300">{value}</strong>
            <span class="mt-2 block text-[10px] sm:text-xs md:text-sm uppercase tracking-[0.15em] sm:tracking-[0.18em] text-zinc-400">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
