---
import { whatsappHref } from './site';
const { title = 'Konsultasi Service & Cek Kendaraan', text = 'Hubungi Redneck EV untuk konsultasi service, pengecekan, atau perawatan sepeda listrik & motor listrik sesuai kebutuhan harian Anda.' } = Astro.props;
---

<section class="py-20">
  <div class="container-shell">
    <div class="overflow-hidden rounded-lg border border-red-500/25 bg-[linear-gradient(135deg,rgba(239,29,50,0.24),rgba(255,122,26,0.14)_45%,rgba(12,13,17,0.96))] p-8 shadow-2xl shadow-red-950/30 sm:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.28em] text-orange-200">WhatsApp</p>
          <h2 class="mt-3 text-3xl font-black uppercase text-white sm:text-5xl">{title}</h2>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-zinc-200">{text}</p>
        </div>
        <a class="rounded-sm bg-red-600 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-white shadow-xl shadow-red-950/50 transition hover:bg-orange-500" href={whatsappHref} target="_blank" rel="noreferrer">
          Chat Sekarang
        </a>
      </div>
    </div>
  </div>
</section>
