---
const reasons = [
  ['Detail Checking', 'Pengecekan kelistrikan, battery, dan wiring yang rapi untuk meminimalkan kendala di jalan.'],
  ['Daily Service', 'Perawatan rutin untuk sepeda & motor listrik agar selalu aman dan siap dipakai harian.'],
  ['Lithium Upgrade', 'Upgrade battery lithium dengan standard keselamatan tinggi dan rapi.'],
  ['Home Service', 'Layanan service panggilan ke rumah untuk pengecekan dan perbaikan praktis.'],
];
---

<section class="py-20">
  <div class="container-shell grid gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:items-center">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.28em] text-orange-300">WHY CHOOSE US</p>
      <h2 class="mt-3 text-3xl font-black uppercase text-white sm:text-5xl leading-tight">SOLUSI TEKNIS EV YANG TEPAT & TERJANGKAU.</h2>
      <p class="mt-5 text-lg leading-8 text-zinc-400">Redneck EV menghadirkan solusi teknis untuk sepeda listrik & motor listrik dengan pengecekan detail, penanganan rapi, dan biaya service yang tetap masuk akal.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {reasons.map(([title, body], index) => (
        <article class="garage-card rounded-lg p-6 transition duration-300 hover:-translate-y-1 hover:border-red-500/30">
          <span class="text-sm font-black text-red-400">0{index + 1}</span>
          <h3 class="mt-5 text-xl font-black uppercase text-white">{title}</h3>
          <p class="mt-3 leading-7 text-zinc-400">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>


