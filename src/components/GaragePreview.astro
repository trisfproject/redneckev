---
import { garageImages, withBase } from './site';
const { full = false } = Astro.props;
const images = full ? garageImages : garageImages.slice(0, 3);
---

<section class="py-20 sm:py-24">
  <div class="container-shell">
    <div class="mb-10 flex flex-col justify-between gap-5 lg:flex-row lg:items-end">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.28em] text-red-400">Inside The Garage</p>
        <h2 class="mt-3 text-3xl font-black uppercase text-white sm:text-5xl">Repair process, battery bench, before-after builds.</h2>
      </div>
      {!full && (
        <a class="w-fit rounded-sm border border-white/15 px-5 py-3 text-sm font-black uppercase tracking-[0.16em] text-zinc-100 transition hover:border-orange-400" href={withBase('garage/')}>
          Open Garage
        </a>
      )}
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {images.map((image, index) => (
        <figure class={`garage-card overflow-hidden rounded-lg ${index === 0 && !full ? 'md:col-span-2' : ''}`}>
          <img class="h-72 w-full object-cover transition duration-500 hover:scale-105" src={image.src} alt={image.alt} loading="lazy" />
          <figcaption class="flex items-center justify-between gap-4 p-5">
            <span class="font-black uppercase tracking-[0.12em] text-white">{image.title}</span>
            <span class="h-2 w-12 rounded-full bg-gradient-to-r from-red-600 to-orange-400"></span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
