---
import Layout from '../../layouts/Layout.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import CTASection from '../../components/CTASection.astro';
---

<Layout title="Layanan Service Sepeda & Motor Listrik | Redneck EV" description="Layanan perawatan & perbaikan EV di Cilegon. Pengecekan detail, service rutin sepeda & motor listrik, upgrade baterai lithium, tuning controller, dan home service.">
  <section class="container-shell pt-36 pb-8">
    <p class="text-sm font-black uppercase tracking-[0.28em] text-red-400">Redneck EV Services</p>
    <h1 class="mt-4 max-w-4xl text-4xl font-black uppercase text-white sm:text-6xl">EV Service, Maintenance, and System Care.</h1>
    <p class="mt-6 max-w-3xl text-base sm:text-lg leading-relaxed sm:leading-8 text-zinc-400">Setiap unit dicek dari gejala, wiring, battery, controller, charger, hingga kebutuhan riding. Fokus kami: hasil yang terasa enak dipakai dan tetap masuk akal secara teknis.</p>
  </section>
  <ServicesSection full />
  <CTASection title="Konsultasi Service & Cek Kendaraan" text="Ceritakan keluhan unit dan lokasi Anda. Untuk kasus tertentu, Redneck EV bisa bantu dengan home service atau pickup recommendation." />
</Layout>
