---
import Layout from '../../layouts/Layout.astro';
import { whatsappHref } from '../../components/site';
---

<Layout title="Contact | Redneck EV" description="Hubungi Redneck EV melalui WhatsApp, sosial media, jam operasional, dan lokasi placeholder Google Maps untuk service EV.">
  <section class="container-shell pt-36 pb-20">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.28em] text-red-400">Contact</p>
        <h1 class="mt-4 text-4xl font-black uppercase text-white sm:text-6xl">Tell us what your EV needs.</h1>
        <p class="mt-6 text-lg leading-8 text-zinc-400">Kirim gejala, foto unit, lokasi, dan target penggunaan. Kami bantu arahkan apakah cukup service, perlu upgrade, atau cocok untuk custom build.</p>
        <a class="mt-8 inline-flex rounded-sm bg-red-600 px-6 py-4 text-sm font-black uppercase tracking-[0.18em] text-white transition hover:bg-orange-500" href={whatsappHref} target="_blank" rel="noreferrer">
          Chat WhatsApp
        </a>
      </div>
      <div class="grid gap-5">
        <article class="garage-card rounded-lg p-6">
          <h2 class="text-xl font-black uppercase text-white">Business Hours</h2>
          <p class="mt-3 text-zinc-400">Monday-Saturday, 09:00-18:00</p>
          <p class="mt-1 text-zinc-500">Emergency and home service by appointment.</p>
        </article>
        <article class="garage-card rounded-lg p-6">
          <h2 class="text-xl font-black uppercase text-white">Social Media</h2>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="rounded-sm border border-white/15 px-4 py-2 text-zinc-300 hover:border-red-400 hover:text-white" href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
            <a class="rounded-sm border border-white/15 px-4 py-2 text-zinc-300 hover:border-red-400 hover:text-white" href="https://facebook.com/" target="_blank" rel="noreferrer">Facebook</a>
            <a class="rounded-sm border border-white/15 px-4 py-2 text-zinc-300 hover:border-red-400 hover:text-white" href="https://tiktok.com/" target="_blank" rel="noreferrer">TikTok</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="container-shell pb-20">
    <div class="garage-card grid min-h-80 place-items-center rounded-lg border-dashed p-8 text-center">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.28em] text-orange-300">Google Maps Placeholder</p>
        <h2 class="mt-4 text-3xl font-black uppercase text-white">Redneck EV Garage Location</h2>
        <p class="mt-4 max-w-2xl leading-7 text-zinc-400">Embed Google Maps here once the official workshop location is ready to publish.</p>
      </div>
    </div>
  </section>
</Layout>
