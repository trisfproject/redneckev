---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../components/site';
---

<Layout title="404 - Battery Connection Lost | Redneck EV" description="Halaman tidak ditemukan. Halaman yang Anda cari mungkin telah dipindah, dihapus, atau tidak pernah ada." noindex={true}>
  <section class="container-shell min-h-[calc(100vh-22rem)] flex flex-col justify-center items-center text-center pt-36 pb-20">
    <div class="relative w-full max-w-lg p-8 sm:p-12 garage-card rounded-lg border border-red-500/20 bg-[linear-gradient(135deg,rgba(239,29,50,0.12),rgba(12,13,17,0.98))] shadow-2xl shadow-red-950/20">
      
      <!-- Premium red cinematic ambient glow -->
      <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-48 h-48 bg-red-600/20 rounded-full blur-[70px] pointer-events-none"></div>

      <!-- EV / Battery connection lost themed SVG icon -->
      <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-sm border border-red-500/35 bg-red-500/10 text-red-500 red-glow mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
          <!-- Battery shell outline -->
          <rect x="2" y="6" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5" />
          <!-- Battery terminal protrusion -->
          <path d="M21 10v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <!-- Diagonal connection break slash -->
          <path d="M4 19L20 5" stroke="#ef1d32" stroke-width="2" stroke-linecap="round" />
          <!-- Small lightning indicator inside battery -->
          <path d="M9 10l-2 3h4l-2 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" class="animate-pulse" />
        </svg>
      </div>

      <span class="text-sm font-black uppercase tracking-[0.3em] text-red-400">404 Error</span>
      
      <h1 class="mt-4 text-3xl font-black uppercase tracking-normal text-white sm:text-4xl text-balance">
        Battery Connection Lost
      </h1>

      <p class="mt-4 text-sm sm:text-base leading-relaxed text-zinc-300">
        The page you are looking for may have been moved, removed, or no longer exists.
      </p>

      <p class="mt-3 text-xs leading-relaxed text-zinc-500">
        Return to homepage to continue browsing our services.
      </p>

      <div class="mt-8">
        <a class="inline-flex w-full sm:w-auto justify-center items-center rounded-sm bg-red-600 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-white shadow-xl shadow-red-950/50 transition hover:bg-orange-500" href={withBase('')} aria-label="Back to Homepage">
          Back to Home
        </a>
      </div>

      <div class="mt-10 border-t border-white/5 pt-6 text-[10px] sm:text-xs font-black uppercase tracking-[0.2em] text-zinc-500">
        REDNECK EV — Service Sepeda Listrik & Motor Listrik
      </div>
    </div>
  </section>
</Layout>
